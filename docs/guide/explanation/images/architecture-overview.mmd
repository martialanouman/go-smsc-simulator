flowchart TB
  yml["<b>smsc-simulator.yml</b><br/><i>entrée de config UNIQUE, lue au démarrage</i>"]

  subgraph binaire["smsc-simulator — binaire Go unique"]
    direction TB
    subgraph v1["SMSC virtuel #1"]
      direction TB
      e1["SMPP Server Engine<br/>Scenario Engine · Fault Injector<br/>Schedule Runner (tick)<br/>per_bind_clock · PDU Recorder (ring)"]
    end
    subgraph v2["SMSC virtuel #2 … N"]
      direction TB
      e2["SMPP Server Engine<br/>Scenario Engine · Fault Injector<br/>Schedule Runner (tick)<br/>per_bind_clock · PDU Recorder (ring)"]
    end
    obs["<b>Observability API</b> — HTTP, READ-ONLY, 1 port<br/>GET binds · received-pdus · logical-clock<br/>GET health · metrics<br/><i>ni config, ni mutation</i>"]
  end

  gw["<b>Passerelle sous test</b><br/><i>traite chaque SMSC virtuel comme un vrai connecteur</i>"]

  yml -->|parsée une fois ; aucune reconfiguration runtime| binaire
  v1 -.-> obs
  v2 -.-> obs
  gw -->|bind SMPP — un par port| v1
  gw -->|bind SMPP — un par port| v2

  classDef cfg fill:#fef3c7,stroke:#d97706,color:#111827;
  classDef vsmsc fill:#dbeafe,stroke:#2563eb,color:#111827;
  classDef readonly fill:#dcfce7,stroke:#16a34a,color:#111827;
  classDef ext fill:#f3f4f6,stroke:#6b7280,color:#111827;
  class yml cfg;
  class e1,e2 vsmsc;
  class obs readonly;
  class gw ext;
